<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Finly.ViewModels"
             xmlns:models="clr-namespace:Finly.Models"
             xmlns:converters="clr-namespace:Finly.Converters"
             xmlns:views="clr-namespace:Finly.Views"
             xmlns:modelWindows="clr-namespace:Finly.Views.ModelWindows"
             x:Class="Finly.MainPage"
             Title="Finly"
             BackgroundColor="#F5F7FA">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StringToBoolConverter x:Key="StringToBoolConverter"/>
            <converters:NetBalanceConverter x:Key="NetBalanceConverter"/>
            <converters:NullToColorConverter x:Key="NullToColorConverter"/>
            <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
            <Shadow x:Key="CardShadow" Brush="#33000000" Offset="0,4" Radius="10" Opacity="0.1"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <!-- Основной контент страницы -->
    <AbsoluteLayout>
        <!-- Основной скроллируемый контент -->
        <ScrollView AbsoluteLayout.LayoutBounds="0,0,1,1"
                    AbsoluteLayout.LayoutFlags="All">
            <VerticalStackLayout Padding="0" Spacing="0" VerticalOptions="Start">

                <!-- 1. HEADER & BALANCE -->
                <Frame BackgroundColor="#4A148C" 
                       Padding="0" 
                       Margin="0,0,0,0"
                       HasShadow="True"
                       CornerRadius="0"
                       HeightRequest="370">
                    <Frame.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#7B1FA2" Offset="0.0"/>
                            <GradientStop Color="#4A148C" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Frame.Background>

                    <Grid Padding="20" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                        <!-- Заголовок и выбор счета -->
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Finly" TextColor="White" FontSize="28" FontAttributes="Bold"/>

                            <!-- Кнопка выбора счета -->
                            <Frame Grid.Column="1"
                                   BackgroundColor="White"
                                   CornerRadius="20"
                                   Padding="10,5"
                                   HasShadow="True">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ShowAccountSelectorCommand}"/>
                                </Frame.GestureRecognizers>
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="👤" FontSize="18"/>
                                    <Label Text="{Binding SelectedAccountName}" 
                                           TextColor="#4A148C" 
                                           FontSize="14" 
                                           FontAttributes="Bold"
                                           VerticalOptions="Center"/>
                                    <Label Text="▼" TextColor="#4A148C" FontSize="12" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Frame>
                        </Grid>

                        <!-- Баланс -->
                        <VerticalStackLayout Grid.Row="1" Margin="0,10,0,10">
                            <Label Text="Общий баланс" TextColor="White" FontSize="14" Opacity="0.8"/>
                            <Label Text="{Binding TotalBalance, StringFormat='{0:C}'}" 
                                   TextColor="White" 
                                   FontSize="38" 
                                   FontAttributes="Bold"/>
                        </VerticalStackLayout>

                        <!-- Статистика (Доходы/Расходы за все время) -->
                        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="15">
                            <!-- Доходы всего -->
                            <Frame Grid.Column="0" BackgroundColor="#2E7D32" Padding="15" CornerRadius="12" HasShadow="True">
                                <VerticalStackLayout>
                                    <Label Text="Доходы всего" TextColor="White" FontSize="13" Opacity="0.9"/>
                                    <Label Text="{Binding TotalIncome, StringFormat='{0:C}'}" 
                                           TextColor="White" 
                                           FontSize="20" 
                                           FontAttributes="Bold"/>
                                </VerticalStackLayout>
                            </Frame>
                            <!-- Расходы всего -->
                            <Frame Grid.Column="1" BackgroundColor="#C62828" Padding="15" CornerRadius="12" HasShadow="True">
                                <VerticalStackLayout>
                                    <Label Text="Расходы всего" TextColor="White" FontSize="13" Opacity="0.9"/>
                                    <Label Text="{Binding TotalExpenses, StringFormat='{0:C}'}" 
                                           TextColor="White" 
                                           FontSize="20" 
                                           FontAttributes="Bold"/>
                                </VerticalStackLayout>
                            </Frame>
                        </Grid>

                        <!-- Кнопки действий -->
                        <HorizontalStackLayout Grid.Row="3" Spacing="15" VerticalOptions="End" Margin="0, 25, 0, 0">
                            <Frame BackgroundColor="White" Padding="12" CornerRadius="15" HasShadow="True" HeightRequest="55" WidthRequest="55">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding AddTransactionCommand}"/>
                                </Frame.GestureRecognizers>
                                <Label Text="+" FontSize="24" TextColor="#4A148C" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold"/>
                            </Frame>

                            <Frame BackgroundColor="White" Padding="12" CornerRadius="15" HasShadow="True" HeightRequest="55" WidthRequest="55">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateToPageCommand}" CommandParameter="Reports"/>
                                </Frame.GestureRecognizers>
                                <Label Text="📊" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Frame>

                            <Frame BackgroundColor="White" Padding="12" CornerRadius="15" HasShadow="True" HeightRequest="55" WidthRequest="55">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateToPageCommand}" CommandParameter="Accounts"/>
                                </Frame.GestureRecognizers>
                                <Label Text="💳" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Frame>
                        </HorizontalStackLayout>
                    </Grid>
                </Frame>

                <!-- Сегодняшняя статистика -->
                <Frame BackgroundColor="White"
                       Padding="15"
                       Margin="20,15,20,10"
                       CornerRadius="15"
                       HasShadow="True">
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="5" HorizontalOptions="Center">
                            <Label Text="📈" FontSize="20" HorizontalOptions="Center"/>
                            <Label Text="Сегодня доход" FontSize="12" TextColor="#666" HorizontalOptions="Center"/>
                            <Label Text="{Binding TodayIncome, StringFormat='{0:C}'}" 
                                   FontSize="16" 
                                   TextColor="#2E7D32" 
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="5" HorizontalOptions="Center">
                            <Label Text="📉" FontSize="20" HorizontalOptions="Center"/>
                            <Label Text="Сегодня расход" FontSize="12" TextColor="#666" HorizontalOptions="Center"/>
                            <Label Text="{Binding TodayExpenses, StringFormat='{0:C}'}" 
                                   FontSize="16" 
                                   TextColor="#C62828" 
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="2" Spacing="5" HorizontalOptions="Center">
                            <Label Text="💰" FontSize="20" HorizontalOptions="Center"/>
                            <Label Text="За сегодня" FontSize="12" TextColor="#666" HorizontalOptions="Center"/>
                            <Label Text="{Binding TodayIncome, Converter={StaticResource NetBalanceConverter}}" 
                                   FontSize="16" 
                                   TextColor="#4A148C" 
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- 2. SEARCH BAR -->
                <ContentView Padding="20,10,20,10">
                    <Frame BackgroundColor="White" 
                           CornerRadius="12" 
                           Padding="15,10"
                           HasShadow="True"
                           BorderColor="#EEEEEE">
                        <Grid ColumnDefinitions="Auto,*">
                            <Label Grid.Column="0" Text="🔍" FontSize="20" VerticalOptions="Center" Margin="0,0,10,0"/>
                            <Entry Grid.Column="1" Placeholder="Поиск операции..." 
                                   PlaceholderColor="#999"
                                   TextColor="#333"
                                   BackgroundColor="Transparent" 
                                   FontSize="16"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Frame>
                </ContentView>

                <!-- 3. TRANSACTIONS LIST -->
                <Label Text="Последние операции" 
                       FontSize="18" 
                       FontAttributes="Bold" 
                       TextColor="#222"
                       Margin="20,5,20,10"/>

                <CollectionView ItemsSource="{Binding RecentTransactionsDisplay}" 
                                SelectionMode="None"
                                BackgroundColor="Transparent"
                                Margin="0,0,0,20">

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:TransactionDisplayItem">
                            <SwipeView>
                                <!-- ИЗМЕНЕНО: Увеличен отступ и добавлено закругление для свайпа влево (Редактировать) -->
                                <SwipeView.LeftItems>
                                    <SwipeItems Mode="Reveal">
                                        <SwipeItemView BackgroundColor="#1976D2" 
                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=EditTransactionCommand}"
                                                       CommandParameter="{Binding .}">
                                            <Grid WidthRequest="80" HeightRequest="100" Margin="5,5,0,5">
                                                <!-- Увеличен отступ слева и сверху/снизу -->
                                                <Border StrokeThickness="0"
                                                        BackgroundColor="#1976D2"
                                                        StrokeShape="RoundRectangle 15">
                                                    <!-- Закругленные углы 15px -->
                                                    <Label Text="✏️" FontSize="24" 
                                                           HorizontalOptions="Center" 
                                                           VerticalOptions="Center"
                                                           TextColor="White"/>
                                                </Border>
                                            </Grid>
                                        </SwipeItemView>
                                    </SwipeItems>
                                </SwipeView.LeftItems>

                                <!-- ИЗМЕНЕНО: Увеличен отступ и добавлено закругление для свайпа вправо (Удалить) -->
                                <SwipeView.RightItems>
                                    <SwipeItems Mode="Reveal">
                                        <SwipeItemView BackgroundColor="#D32F2F" 
                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=DeleteTransactionCommand}"
                                                       CommandParameter="{Binding .}">
                                            <Grid WidthRequest="80" HeightRequest="100" Margin="0,5,5,5">
                                                <!-- Увеличен отступ справа и сверху/снизу -->
                                                <Border StrokeThickness="0"
                                                        BackgroundColor="#D32F2F"
                                                        StrokeShape="RoundRectangle 15">
                                                    <!-- Закругленные углы 15px -->
                                                    <Label Text="🗑️" FontSize="24" 
                                                           HorizontalOptions="Center" 
                                                           VerticalOptions="Center"
                                                           TextColor="White"/>
                                                </Border>
                                            </Grid>
                                        </SwipeItemView>
                                    </SwipeItems>
                                </SwipeView.RightItems>

                                <!-- Карточка транзакции (без изменений) -->
                                <ContentView Padding="20,5,20,5">
                                    <Frame BackgroundColor="White" 
                                           CornerRadius="15" 
                                           Padding="15"
                                           HasShadow="True"
                                           BorderColor="#F0F0F0">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                                            <Frame Grid.Column="0" 
                                                   WidthRequest="50" 
                                                   HeightRequest="50" 
                                                   CornerRadius="25"
                                                   BackgroundColor="#F3E5F5"
                                                   Padding="0"
                                                   IsClippedToBounds="True"
                                                   HasShadow="False">
                                                <Label Text="{Binding CategoryIcon}" 
                                                       FontSize="24"
                                                       HorizontalOptions="Center" 
                                                       VerticalOptions="Center"/>
                                            </Frame>

                                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                                <Label Text="{Binding Description}" 
                                                       FontSize="16" 
                                                       FontAttributes="Bold"
                                                       TextColor="#222"
                                                       LineBreakMode="TailTruncation"/>

                                                <HorizontalStackLayout Spacing="6">
                                                    <Label Text="{Binding CategoryName}" 
                                                           FontSize="13" 
                                                           TextColor="#666"/>
                                                    <Label Text="•" FontSize="13" TextColor="#CCC"
                                                           IsVisible="{Binding AccountName, Converter={StaticResource StringToBoolConverter}}"/>
                                                    <Label Text="{Binding AccountName}" 
                                                           FontSize="13" 
                                                           TextColor="#666"
                                                           IsVisible="{Binding AccountName, Converter={StaticResource StringToBoolConverter}}"/>
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>

                                            <VerticalStackLayout Grid.Column="2" 
                                                                 HorizontalOptions="End" 
                                                                 Spacing="4"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding FormattedAmount}" 
                                                       FontSize="18" 
                                                       FontAttributes="Bold"
                                                       TextColor="{Binding AmountColor}"
                                                       HorizontalTextAlignment="End"/>
                                                <Label Text="{Binding Date, StringFormat='{0:dd.MM HH:mm}'}" 
                                                       FontSize="11" 
                                                       TextColor="#999"
                                                       HorizontalTextAlignment="End"/>
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Frame>
                                </ContentView>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" 
                                            VerticalOptions="Center" 
                                            Padding="40"
                                            Spacing="15">
                            <Label Text="📭" FontSize="60" HorizontalOptions="Center"/>
                            <Label Text="Операций нет" 
                                   FontSize="18" 
                                   TextColor="#666" 
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>

                <!-- Loading indicator -->
                <ActivityIndicator IsVisible="{Binding IsBusy}" 
                                   IsRunning="{Binding IsBusy}" 
                                   Color="#4A148C"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"
                                   Margin="0,20"/>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Popup выбора счета (поверх основного контента) -->
        <AbsoluteLayout 
            IsVisible="{Binding IsPopupVisible}"
            BackgroundColor="#80000000"
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            AbsoluteLayout.LayoutFlags="All"
            InputTransparent="False">

            <!-- Затемненная область для закрытия по клику -->
            <BoxView 
                AbsoluteLayout.LayoutBounds="0,0,1,1"
                AbsoluteLayout.LayoutFlags="All"
                BackgroundColor="Transparent">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ClosePopupCommand}"/>
                </BoxView.GestureRecognizers>
            </BoxView>

            <!-- Popup контент -->
            <modelWindows:AccountsPopup 
                BindingContext="{Binding}"
                AbsoluteLayout.LayoutBounds="0.5,0.5,AutoSize,AutoSize"
                AbsoluteLayout.LayoutFlags="PositionProportional"
                InputTransparent="False"/>
        </AbsoluteLayout>
    </AbsoluteLayout>
</ContentPage>