<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Finly.ViewModels"
             xmlns:converters="clr-namespace:Finly.Converters"
             x:Class="Finly.Views.AddAccountPage"
             x:DataType="viewmodels:AddAccountViewModel"
             Title="{Binding Title}"
             BackgroundColor="#F8F9FE">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- Ссылки на конвертеры из App.xaml (они уже там есть) -->

            <!-- Общие стили для карточек -->
            <Style x:Key="CardFrameStyle" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="White"/>
                <Setter Property="Padding" Value="20"/>
                <Setter Property="CornerRadius" Value="20"/>
                <Setter Property="HasShadow" Value="True"/>
                <Setter Property="BorderColor" Value="Transparent"/>
                <Setter Property="Margin" Value="15,0,15,15"/>
            </Style>

            <Style x:Key="LabelTitleStyle" TargetType="Label">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="TextColor" Value="#636E72"/>
                <Setter Property="Margin" Value="0,0,0,5"/>
            </Style>

            <!-- Стиль для рамки ввода без фона -->
            <Style x:Key="InputFrameStyle" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="White"/>
                <Setter Property="Padding" Value="15,5"/>
                <Setter Property="CornerRadius" Value="15"/>
                <Setter Property="HasShadow" Value="False"/>
                <Setter Property="BorderColor" Value="#E0E0E0"/>
            </Style>

            <!-- Стиль для рамки ошибки -->
            <Style x:Key="ErrorFrameStyle" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="White"/>
                <Setter Property="BorderColor" Value="#D63031"/>
                <Setter Property="Padding" Value="15,5"/>
                <Setter Property="CornerRadius" Value="15"/>
                <Setter Property="HasShadow" Value="False"/>
            </Style>

            <!-- Стиль для рамки успеха -->
            <Style x:Key="SuccessFrameStyle" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="White"/>
                <Setter Property="BorderColor" Value="#2E7D32"/>
                <Setter Property="Padding" Value="15,5"/>
                <Setter Property="CornerRadius" Value="15"/>
                <Setter Property="HasShadow" Value="False"/>
            </Style>

            <!-- Стиль для Picker (select) -->
            <Style x:Key="PickerStyle" TargetType="Picker">
                <Setter Property="BackgroundColor" Value="White"/>
                <Setter Property="TextColor" Value="#2D3436"/>
                <Setter Property="TitleColor" Value="#B2BEC3"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Margin" Value="10,0,0,0"/>
            </Style>

            <!-- Стиль для Entry -->
            <Style x:Key="EntryStyle" TargetType="Entry">
                <Setter Property="BackgroundColor" Value="White"/>
                <Setter Property="TextColor" Value="#2D3436"/>
                <Setter Property="PlaceholderColor" Value="#B2BEC3"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Margin" Value="10,0,0,0"/>
            </Style>

            <Shadow x:Key="CardShadow" Brush="#6C63FF" Offset="0,4" Radius="12" Opacity="0.1"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Frame Grid.Row="0" 
               BackgroundColor="#6C63FF"
               Padding="0"
               CornerRadius="0"
               HasShadow="True">
            <Frame.Shadow>
                <Shadow Brush="#6C63FF" Offset="0,6" Radius="15" Opacity="0.4"/>
            </Frame.Shadow>

            <Grid Padding="20,15,20,15" ColumnDefinitions="*,Auto">
                <HorizontalStackLayout Grid.Column="0" Spacing="10">
                    <Label Text="🏦" 
                           FontSize="24" 
                           TextColor="White"/>
                    <Label Text="{Binding Title}" 
                           TextColor="White" 
                           FontSize="24" 
                           FontAttributes="Bold"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <!-- Кнопка закрытия -->
                <Frame Grid.Column="1"
                       BackgroundColor="White"
                       CornerRadius="18"
                       Padding="0"
                       HeightRequest="40"
                       WidthRequest="40"
                       HasShadow="True"
                       IsClippedToBounds="True">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                    </Frame.GestureRecognizers>
                    <Label Text="✕" 
                           FontSize="20" 
                           TextColor="#6C63FF" 
                           HorizontalOptions="Center" 
                           VerticalOptions="Center"
                           FontAttributes="Bold"/>
                </Frame>
            </Grid>
        </Frame>

        <!-- FORM -->
        <ScrollView Grid.Row="1" Padding="0,15,0,0">
            <VerticalStackLayout Spacing="0">

                <!-- Блок Название счета -->
                <Frame Style="{StaticResource CardFrameStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Название счета" Style="{StaticResource LabelTitleStyle}"/>

                        <Frame Style="{StaticResource InputFrameStyle}"
                               BorderColor="{Binding NameBorderColor}">
                            <Entry Text="{Binding AccountName, Mode=TwoWay}" 
                                   Placeholder="Например: Наличные, Сбербанк" 
                                   Style="{StaticResource EntryStyle}"
                                   x:Name="NameEntry"
                                   TextChanged="OnNameTextChanged"/>
                        </Frame>

                        <!-- Индикатор валидации -->
                        <Frame Style="{Binding NameValidationStyle}"
                               IsVisible="{Binding ShowNameValidation}">
                            <Label Text="{Binding NameValidationMessage}"
                                   TextColor="{Binding NameValidationTextColor}"
                                   FontSize="12"/>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- Блок Тип счета -->
                <Frame Style="{StaticResource CardFrameStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Тип счета" Style="{StaticResource LabelTitleStyle}"/>

                        <Frame Style="{StaticResource InputFrameStyle}"
                               Padding="0">
                            <Picker ItemsSource="{Binding AccountTypeList}" 
                                    SelectedItem="{Binding SelectedAccountType}" 
                                    Title="Выберите тип счета"
                                    Style="{StaticResource PickerStyle}"
                                    x:Name="TypePicker"
                                    SelectedIndexChanged="OnTypeSelected"/>
                        </Frame>

                        <!-- Индикатор валидации -->
                        <Frame Style="{Binding TypeValidationStyle}"
                               IsVisible="{Binding ShowTypeValidation}">
                            <Label Text="{Binding TypeValidationMessage}"
                                   TextColor="{Binding TypeValidationTextColor}"
                                   FontSize="12"/>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- Блок Начальный баланс (ИСПРАВЛЕНО: всегда рубли) -->
                <Frame Style="{StaticResource CardFrameStyle}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Начальный баланс" Style="{StaticResource LabelTitleStyle}"/>

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Frame Grid.Column="0"
                   Style="{StaticResource InputFrameStyle}"
                   BorderColor="{Binding BalanceBorderColor}">
                                <Entry Text="{Binding FormattedBalance, Mode=TwoWay}" 
                       Keyboard="Numeric" 
                       Placeholder="0.00"
                       Style="{StaticResource EntryStyle}"
                       FontSize="20"
                       FontAttributes="Bold"
                       x:Name="BalanceEntry"
                       TextChanged="OnBalanceTextChanged"/>
                            </Frame>

                            <!-- Фиксированная валюта - рубли -->
                            <Frame Grid.Column="1"
                   BackgroundColor="White"
                   Padding="15,5"
                   CornerRadius="15"
                   HasShadow="False"
                   BorderColor="#E0E0E0">
                                <Label Text="₽" 
                       FontSize="18" 
                       FontAttributes="Bold"
                       TextColor="#6C63FF"
                       VerticalOptions="Center"/>
                            </Frame>
                        </Grid>

                        <!-- ВОЗВРАЩАЕМ индикатор валидации -->
                        <Frame Style="{Binding BalanceValidationStyle}"
               IsVisible="{Binding ShowBalanceValidation}">
                            <Label Text="{Binding BalanceValidationMessage}"
                   TextColor="{Binding BalanceValidationTextColor}"
                   FontSize="12"/>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>
                <Frame Style="{StaticResource CardFrameStyle}">
    <VerticalStackLayout Spacing="10">
        <Label Text="Начальный баланс" Style="{StaticResource LabelTitleStyle}"/>

        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <Frame Grid.Column="0"
                   Style="{StaticResource InputFrameStyle}"
                   BorderColor="{Binding BalanceBorderColor}">
                <Entry Text="{Binding FormattedBalance, Mode=TwoWay}" 
                       Keyboard="Numeric" 
                       Placeholder="0.00"
                       Style="{StaticResource EntryStyle}"
                       FontSize="20"
                       FontAttributes="Bold"
                       x:Name="BalanceEntry"
                       TextChanged="OnBalanceTextChanged"/>
            </Frame>

            <!-- Фиксированная валюта - рубли -->
            <Frame Grid.Column="1"
                   BackgroundColor="White"
                   Padding="15,5"
                   CornerRadius="15"
                   HasShadow="False"
                   BorderColor="#E0E0E0">
                <Label Text="₽" 
                       FontSize="18" 
                       FontAttributes="Bold"
                       TextColor="#6C63FF"
                       VerticalOptions="Center"/>
            </Frame>
        </Grid>

        <!-- ВОЗВРАЩАЕМ индикатор валидации -->
        <Frame Style="{Binding BalanceValidationStyle}"
               IsVisible="{Binding ShowBalanceValidation}">
            <Label Text="{Binding BalanceValidationMessage}"
                   TextColor="{Binding BalanceValidationTextColor}"
                   FontSize="12"/>
        </Frame>
    </VerticalStackLayout>
</Frame>

                <!-- Блок Название банка (для банковских счетов) -->
                <Frame Style="{StaticResource CardFrameStyle}"
                       IsVisible="{Binding IsBankAccount}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Название банка (необязательно)" Style="{StaticResource LabelTitleStyle}"/>

                        <Frame Style="{StaticResource InputFrameStyle}">
                            <Entry Text="{Binding BankName}" 
                                   Placeholder="Например: Сбербанк, Тинькофф" 
                                   Style="{StaticResource EntryStyle}"/>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- Блок Номер счета (для банковских счетов) -->
                <Frame Style="{StaticResource CardFrameStyle}"
                       IsVisible="{Binding IsBankAccount}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Номер счета/карты (необязательно)" Style="{StaticResource LabelTitleStyle}"/>

                        <Frame Style="{StaticResource InputFrameStyle}">
                            <Entry Text="{Binding AccountNumber}" 
                                   Placeholder="Например: ****1234" 
                                   Style="{StaticResource EntryStyle}"
                                   Keyboard="Telephone"/>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- Блок Настройки -->
                <Frame Style="{StaticResource CardFrameStyle}">
                    <VerticalStackLayout Spacing="15">

                        <!-- Основной счет -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <HorizontalStackLayout Grid.Column="0" Spacing="8">
                                <Label Text="⭐" FontSize="18"/>
                                <Label Text="Основной счет" FontSize="16" TextColor="#2D3436" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <CheckBox Grid.Column="1" 
                                      IsChecked="{Binding IsPrimary}" 
                                      Color="#6C63FF" 
                                      VerticalOptions="Center"
                                      Scale="1.2"/>
                        </Grid>

                        <BoxView HeightRequest="1" BackgroundColor="#F0F0F0" Margin="0,5"/>

                        <!-- Активен -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <HorizontalStackLayout Grid.Column="0" Spacing="8">
                                <Label Text="✅" FontSize="18"/>
                                <Label Text="Активен" FontSize="16" TextColor="#2D3436" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <CheckBox Grid.Column="1" 
                                      IsChecked="{Binding IsActive}" 
                                      Color="#00D9A5" 
                                      VerticalOptions="Center"
                                      Scale="1.2"/>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Кнопки действий -->
                <ContentView Padding="15,5,15,25">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">

                        <!-- Кнопка сохранения (всегда зеленая) -->
                        <Button Grid.Column="0" 
                                Grid.ColumnSpan="2"
                                Text="💾 Сохранить" 
                                Command="{Binding SaveAccountCommand}" 
                                BackgroundColor="#00D9A5" 
                                TextColor="White" 
                                FontSize="16"
                                FontAttributes="Bold"
                                CornerRadius="15"
                                HeightRequest="60"
                                IsVisible="{Binding IsEditMode, Converter={StaticResource InvertedBoolConverter}}">
                            <Button.Shadow>
                                <Shadow Brush="#00D9A5" Offset="0,6" Radius="15" Opacity="0.4"/>
                            </Button.Shadow>
                        </Button>

                        <!-- Кнопки для режима редактирования -->
                        <Button Grid.Column="0" 
                                Text="🗑️ Удалить" 
                                Command="{Binding DeleteAccountCommand}" 
                                IsVisible="{Binding IsEditMode}" 
                                BackgroundColor="#D63031" 
                                TextColor="White" 
                                FontSize="16"
                                FontAttributes="Bold"
                                CornerRadius="15"
                                HeightRequest="60">
                            <Button.Shadow>
                                <Shadow Brush="#D63031" Offset="0,6" Radius="15" Opacity="0.4"/>
                            </Button.Shadow>
                        </Button>

                        <Button Grid.Column="1" 
                                Text="✖️ Отмена" 
                                Command="{Binding GoBackCommand}" 
                                IsVisible="{Binding IsEditMode}"
                                BackgroundColor="#636E72" 
                                TextColor="White" 
                                FontSize="16"
                                FontAttributes="Bold"
                                CornerRadius="15"
                                HeightRequest="60">
                            <Button.Shadow>
                                <Shadow Brush="#636E72" Offset="0,6" Radius="15" Opacity="0.4"/>
                            </Button.Shadow>
                        </Button>
                    </Grid>
                </ContentView>

                <!-- Добавляем отступ снизу для удобства скролла -->
                <BoxView HeightRequest="20"/>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>